<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>File Host Link Extractor</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0d0d0d;
    --surface: #141414;
    --border: #222;
    --accent: #00e87a;
    --text: #e0e0e0;
    --muted: #555;
    --danger: #ff4455;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'SF Mono', 'Fira Mono', 'JetBrains Mono', monospace;
    min-height: 100vh;
    padding: 24px 16px 48px;
  }

  header { margin-bottom: 28px; }

  .eyebrow {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  h1 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.2;
  }

  .sub {
    font-size: 12px;
    color: var(--muted);
    margin-top: 6px;
    line-height: 1.5;
  }

  .input-row {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  input[type="url"] {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 13px 14px;
    font-size: 13px;
    color: var(--text);
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    -webkit-appearance: none;
  }

  input[type="url"]:focus { border-color: var(--accent); }
  input[type="url"]::placeholder { color: #333; }

  #scanBtn {
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 8px;
    padding: 13px 18px;
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  #scanBtn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Crawl options */
  .crawl-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .crawl-toggle {
    display: flex;
    align-items: center;
    gap: 7px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }

  .crawl-toggle input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--accent);
    cursor: pointer;
  }

  .crawl-toggle span {
    font-size: 12px;
    color: #888;
  }

  .depth-select {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 5px 8px;
    font-size: 12px;
    color: #888;
    font-family: inherit;
    outline: none;
    cursor: pointer;
    display: none;
  }

  .depth-select.visible { display: block; }

  .crawl-limit-note {
    font-size: 10px;
    color: #333;
    display: none;
  }

  .crawl-limit-note.visible { display: block; }

  .hosts-list {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 24px;
  }

  .host-pill {
    font-size: 10px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 7px;
    color: #444;
  }

  /* Status */
  .status-box {
    border-radius: 8px;
    padding: 16px;
    font-size: 13px;
    line-height: 1.6;
    display: none;
  }

  .status-box.visible { display: block; }

  .status-loading {
    background: var(--surface);
    border: 1px solid #1e3a28;
    color: var(--accent);
  }

  .status-error {
    background: #1a0808;
    border: 1px solid #3a1010;
    color: var(--danger);
  }

  .status-empty {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    text-align: center;
  }

  /* Progress log */
  #progressLog {
    font-size: 11px;
    color: #3a6a4a;
    margin-top: 8px;
    max-height: 80px;
    overflow-y: auto;
    line-height: 1.8;
  }

  /* Results */
  #results { display: none; }
  #results.visible { display: block; }

  .results-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .results-count { font-size: 13px; color: var(--muted); }
  .results-count span { color: var(--accent); font-weight: 700; }

  .copy-all-btn {
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 7px 12px;
    font-size: 12px;
    color: #888;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
    -webkit-tap-highlight-color: transparent;
  }

  .copy-all-btn.copied { color: var(--accent); border-color: var(--accent); }

  .host-group { margin-bottom: 20px; }

  .host-label {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: var(--accent);
    text-transform: uppercase;
    padding-bottom: 8px;
    border-bottom: 1px solid #1a1a1a;
    margin-bottom: 8px;
  }

  .host-label .count { color: #333; margin-left: 4px; }

  .link-item {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--surface);
    border: 1px solid #1c1c1c;
    border-radius: 6px;
    padding: 10px 12px;
    margin-bottom: 5px;
  }

  .link-url {
    flex: 1;
    font-size: 11px;
    color: #888;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .link-copy, .link-open {
    background: none;
    border: none;
    color: #333;
    cursor: pointer;
    font-size: 16px;
    padding: 2px 4px;
    flex-shrink: 0;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.15s;
    text-decoration: none;
  }

  .link-copy:active, .link-open:active { color: var(--accent); }
  .link-copy.flashed { color: var(--accent); }

  /* Source badge */
  .link-source {
    font-size: 9px;
    color: #2a4a35;
    background: #0d1f14;
    border-radius: 3px;
    padding: 2px 5px;
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* History */
  #history-section { display: none; margin-top: 32px; }
  #history-section.visible { display: block; }

  .history-header {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: #333;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .clear-history {
    background: none;
    border: none;
    color: #333;
    font-size: 11px;
    cursor: pointer;
    font-family: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  .history-item {
    background: var(--surface);
    border: 1px solid #1a1a1a;
    border-radius: 6px;
    padding: 10px 12px;
    margin-bottom: 6px;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .history-item-url {
    font-size: 11px;
    color: #666;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    margin-bottom: 3px;
  }

  .history-item-meta { font-size: 10px; color: #333; }
  .history-item-meta .hl { color: var(--accent); }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
  .blink { animation: blink 1s infinite; }
</style>
</head>
<body>

<header>
  <div class="eyebrow">File Host Link Extractor</div>
  <h1>K2S &amp; File Host<br>Scanner</h1>
  <p class="sub">Paste a page URL to extract all file host download links</p>
</header>

<div class="input-row">
  <input type="url" id="urlInput" placeholder="https://example.com/post…" autocomplete="off" autocorrect="off" spellcheck="false">
  <button id="scanBtn" onclick="scan()">Scan →</button>
</div>

<div class="crawl-row">
  <label class="crawl-toggle">
    <input type="checkbox" id="recursiveToggle" onchange="toggleRecursive()">
    <span>Crawl same-domain links</span>
  </label>
  <select id="depthSelect" class="depth-select" title="Max pages to crawl">
    <option value="5">up to 5 pages</option>
    <option value="10" selected>up to 10 pages</option>
    <option value="20">up to 20 pages</option>
    <option value="50">up to 50 pages</option>
  </select>
  <span id="crawlNote" class="crawl-limit-note">same domain only</span>
</div>

<div class="hosts-list">
  <span class="host-pill">k2s.cc</span>
  <span class="host-pill">keep2share.cc</span>
  <span class="host-pill">rapidgator.net</span>
  <span class="host-pill">nitroflare.com</span>
  <span class="host-pill">uploaded.net</span>
  <span class="host-pill">1fichier.com</span>
  <span class="host-pill">filefox.cc</span>
  <span class="host-pill">ddownload.com</span>
  <span class="host-pill">katfile.com</span>
  <span class="host-pill">mexashare.com</span>
</div>

<div id="statusLoading" class="status-box status-loading">
  <div><span class="blink">⬤</span> <span id="loadingMsg">Fetching page and scanning for links…</span></div>
  <div id="progressLog"></div>
</div>
<div id="statusError" class="status-box status-error"></div>
<div id="statusEmpty" class="status-box status-empty">No file host links found on this page.</div>

<div id="results">
  <div class="results-header">
    <div class="results-count"><span id="linkCount">0</span> links found</div>
    <button class="copy-all-btn" id="copyAllBtn" onclick="copyAll()">Copy all</button>
  </div>
  <div id="linkGroups"></div>
</div>

<div id="history-section">
  <div class="history-header">
    <span>Scan history</span>
    <button class="clear-history" onclick="clearHistory()">Clear</button>
  </div>
  <div id="historyList"></div>
</div>

<script>
const FILE_HOST_PATTERNS = [
  /https?:\/\/(?:www\.)?k2s\.cc\/file\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?keep2share\.cc\/file\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?keep2share\.com\/file\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?uploaded\.net\/file\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?ul\.to\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?rapidgator\.net\/file\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?nitroflare\.com\/view\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?filefox\.cc\/[a-zA-Z0-9]+[^\s"'<>\)]*\/[^\s"'<>\)]*/gi,
  /https?:\/\/(?:www\.)?ddownload\.com\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?katfile\.com\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?mexashare\.com\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?rosefile\.net\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?fileboom\.me\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?icerbox\.com\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?1fichier\.com\/\?[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?wupfile\.com\/[^\s"'<>\)]+/gi,
  /https?:\/\/(?:www\.)?singlefile\.com\/[^\s"'<>\)]+/gi,
];

let sessionHistory = [];
let allLinks = [];
let allLinkSources = {}; // link -> source page URL

function extractLinks(text) {
  const found = new Set();
  for (const pattern of FILE_HOST_PATTERNS) {
    pattern.lastIndex = 0;
    const matches = text.match(pattern) || [];
    matches.forEach(m => found.add(m.replace(/[.,;)\]>]+$/, '')));
  }
  return [...found];
}

// Extract same-domain page links from Claude's response text
function extractSameDomainPageLinks(text, baseDomain) {
  const allUrls = text.match(/https?:\/\/[^\s"'<>\)]+/gi) || [];
  const pageLinks = new Set();
  for (let u of allUrls) {
    u = u.replace(/[.,;)\]>]+$/, '');
    try {
      const parsed = new URL(u);
      const host = parsed.hostname.replace(/^www\./, '');
      if (host === baseDomain && !isFileOrMedia(parsed.pathname)) {
        pageLinks.add(u);
      }
    } catch {}
  }
  return [...pageLinks];
}

function isFileOrMedia(path) {
  return /\.(jpg|jpeg|png|gif|webp|mp4|mp3|pdf|zip|rar|7z|css|js|ico|svg|woff|woff2|ttf)$/i.test(path);
}

function groupByHost(links) {
  const groups = {};
  for (const link of links) {
    try {
      const host = new URL(link).hostname.replace(/^www\./, '');
      if (!groups[host]) groups[host] = [];
      groups[host].push(link);
    } catch {
      if (!groups['other']) groups['other'] = [];
      groups['other'].push(link);
    }
  }
  return groups;
}

function setStatus(type, msg) {
  ['statusLoading','statusError','statusEmpty','results'].forEach(id => {
    document.getElementById(id).classList.remove('visible');
  });
  if (type === 'loading') document.getElementById('statusLoading').classList.add('visible');
  if (type === 'error') {
    const el = document.getElementById('statusError');
    el.textContent = '✗ ' + (msg || 'Failed to fetch. The page may block scrapers.');
    el.classList.add('visible');
  }
  if (type === 'empty') document.getElementById('statusEmpty').classList.add('visible');
  if (type === 'results') document.getElementById('results').classList.add('visible');
}

function logProgress(msg) {
  const log = document.getElementById('progressLog');
  log.innerHTML += `<div>↳ ${msg}</div>`;
  log.scrollTop = log.scrollHeight;
}

function renderResults(links, sources) {
  allLinks = links;
  allLinkSources = sources || {};
  document.getElementById('linkCount').textContent = links.length;
  const grouped = groupByHost(links);
  const container = document.getElementById('linkGroups');
  container.innerHTML = '';

  for (const [host, hostLinks] of Object.entries(grouped)) {
    const group = document.createElement('div');
    group.className = 'host-group';
    group.innerHTML = `<div class="host-label">${host}<span class="count">(${hostLinks.length})</span></div>`;

    for (const link of hostLinks) {
      const item = document.createElement('div');
      item.className = 'link-item';
      const srcPage = allLinkSources[link];
      const srcBadge = srcPage ? `<span class="link-source" title="${srcPage}">p.${srcPage}</span>` : '';
      const safeLink = link.replace(/'/g, "\\'");
      item.innerHTML = `
        <div class="link-url" title="${link}">${link}</div>
        <button class="link-copy" title="Copy" onclick="copyLink(this, '${safeLink}')">⎘</button>
        <a class="link-open" href="${link}" target="_blank" rel="noopener noreferrer" title="Open">↗</a>
      `;
      group.appendChild(item);
    }
    container.appendChild(group);
  }
  setStatus('results');
}

function copyLink(btn, url) {
  navigator.clipboard.writeText(url).then(() => {
    btn.classList.add('flashed');
    btn.textContent = '✓';
    setTimeout(() => { btn.classList.remove('flashed'); btn.textContent = '⎘'; }, 1500);
  });
}

function copyAll() {
  navigator.clipboard.writeText(allLinks.join('\n')).then(() => {
    const btn = document.getElementById('copyAllBtn');
    btn.textContent = '✓ Copied';
    btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy all'; btn.classList.remove('copied'); }, 2000);
  });
}

function toggleRecursive() {
  const on = document.getElementById('recursiveToggle').checked;
  document.getElementById('depthSelect').classList.toggle('visible', on);
  document.getElementById('crawlNote').classList.toggle('visible', on);
}

async function fetchPageLinks(url) {
  const resp = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-6',
      max_tokens: 1000,
      tools: [{ type: 'web_search_20250305', name: 'web_search' }],
      system: `You are a link extraction tool. Visit the URL given and output ONLY every URL found on the page, one per line. No explanations, no markdown, no commentary. Just URLs.`,
      messages: [{ role: 'user', content: `Extract all links from: ${url}` }]
    })
  });
  const data = await resp.json();
  if (data.error) throw new Error(data.error.message);
  return data.content.filter(b => b.type === 'text').map(b => b.text).join('\n');
}

async function scan() {
  const url = document.getElementById('urlInput').value.trim();
  if (!url) return;

  const recursive = document.getElementById('recursiveToggle').checked;
  const maxPages = recursive ? parseInt(document.getElementById('depthSelect').value) : 1;

  const btn = document.getElementById('scanBtn');
  btn.disabled = true;
  document.getElementById('progressLog').innerHTML = '';
  setStatus('loading');
  document.getElementById('loadingMsg').textContent = recursive
    ? `Crawling up to ${maxPages} pages…`
    : 'Fetching page and scanning for links…';

  const foundLinks = new Set();
  const linkSources = {};
  const visitedPages = new Set();
  const queue = [url];
  let baseDomain;

  try {
    baseDomain = new URL(url).hostname.replace(/^www\./, '');
  } catch {
    setStatus('error', 'Invalid URL.');
    btn.disabled = false;
    return;
  }

  try {
    while (queue.length > 0 && visitedPages.size < maxPages) {
      const current = queue.shift();
      if (visitedPages.has(current)) continue;
      visitedPages.add(current);

      const pageNum = visitedPages.size;
      logProgress(`[${pageNum}/${maxPages}] ${current}`);

      const text = await fetchPageLinks(current);

      // Extract file host links
      const fileLinks = extractLinks(text);
      for (const l of fileLinks) {
        if (!foundLinks.has(l)) {
          foundLinks.add(l);
          linkSources[l] = current;
        }
      }

      // Queue same-domain page links if recursive
      if (recursive && visitedPages.size < maxPages) {
        const pageLinks = extractSameDomainPageLinks(text, baseDomain);
        for (const pl of pageLinks) {
          if (!visitedPages.has(pl) && !queue.includes(pl)) {
            queue.push(pl);
          }
        }
      }
    }

    const links = [...foundLinks];
    if (links.length === 0) {
      setStatus('empty');
      addToHistory(url, 0, visitedPages.size);
    } else {
      renderResults(links, linkSources);
      addToHistory(url, links.length, visitedPages.size);
    }
  } catch (err) {
    setStatus('error', err.message);
  } finally {
    btn.disabled = false;
  }
}

function addToHistory(url, count, pages) {
  sessionHistory.unshift({ url, count, pages, time: new Date().toLocaleTimeString() });
  if (sessionHistory.length > 10) sessionHistory.pop();
  renderHistory();
}

function renderHistory() {
  const section = document.getElementById('history-section');
  const list = document.getElementById('historyList');
  if (sessionHistory.length === 0) { section.classList.remove('visible'); return; }
  section.classList.add('visible');
  list.innerHTML = sessionHistory.map((h, i) => `
    <div class="history-item" onclick="reloadHistory(${i})">
      <div class="history-item-url">${h.url}</div>
      <div class="history-item-meta">${h.time} · <span class="hl">${h.count} links</span>${h.pages > 1 ? ` · ${h.pages} pages` : ''}</div>
    </div>
  `).join('');
}

function reloadHistory(i) {
  document.getElementById('urlInput').value = sessionHistory[i].url;
  scan();
}

function clearHistory() {
  sessionHistory = [];
  renderHistory();
}

document.getElementById('urlInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') scan();
});
</script>
</body>
</html>
